# BOVYN frontend configuration. Copy this file to .env and fill in your values.

# Backend API base URL. Falls back to the public production API if unset.
VITE_BOVYN_API_URL=https://app.bovyn.io/api

# Optional legacy API key. Being replaced by per-user JWT auth.
# Use your own value. Never commit a real key.
VITE_BOVYN_API_KEY=your_api_key_here

# Dev only. Force a subscription tier when running locally (for example: architect).
# VITE_DEV_TIER=architect
